option_settings:
  # ── Load Balancer ───────────────────────────────────────────────────
  aws:elasticbeanstalk:environment:
    LoadBalancerType: application
    EnvironmentType: LoadBalanced

  aws:elasticbeanstalk:environment:process:default:
    Port: 8080                 # MUST match EXPOSE in Dockerfile
    Protocol: HTTP
    HealthCheckPath: /api/health
    HealthCheckInterval: 15
    HealthyThresholdCount: 3
    UnhealthyThresholdCount: 5
    StickinessEnabled: "true"
    StickinessLBCookieDuration: "86400"

  aws:elbv2:listener:default:
    DefaultProcess: default
    ListenerEnabled: "true"
    Protocol: HTTP

  aws:elbv2:listener:443:
    DefaultProcess: default
    ListenerEnabled: "true"
    Protocol: HTTPS
    SSLCertificateArns: "arn:aws:acm:ap-south-1:369435096566:certificate/ad4f70aa-0b8d-4e6a-8c44-cb749493f2d8"
    SSLPolicy: ELBSecurityPolicy-TLS13-1-3-2021-06

  # ── Deployment & Logging ────────────────────────────────────────────
  aws:elasticbeanstalk:command:
    Timeout: 600
    IgnoreHealthCheck: false

  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    DeleteOnTerminate: false
    RetentionInDays: 7
