# Database
MONGODB_URI=mongodb://localhost:27017/powermysport

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server Configuration
PORT=5000
NODE_ENV=development
SERVICE_FEE_RATE=0.05
PLATFORM_COMMISSION_RATE=0

# Redis (used for Socket.IO cross-instance adapter + presence tracking)
# Local:      redis://localhost:6379
# Production: redis://<your-elasticache-cluster>.cache.amazonaws.com:6379
REDIS_URL=redis://localhost:6379

# Kafka (community message pipeline — write buffer for chat messages)
# Local:      localhost:9092  (docker compose -f docker-compose.kafka.yml up -d)
# Production: <aws-msk-broker-1>:9092,<aws-msk-broker-2>:9092
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=powermysport-server

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=teams@powermysport.com
EMAIL_PASSWORD=
EMAIL_FROM=teams@powermysport.com

# AWS S3 Configuration (for file uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=powermysport-uploads

# Google OAuth (if applicable)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Client URL (for CORS and redirects)
CLIENT_URL=http://localhost:3000

# VAPID Keys for Web Push Notifications
# Generate new keys using: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:teams@powermysport.com

# PhonePe Payment Gateway (Sandbox/Production)
PHONEPE_CLIENT_ID=your-phonepe-client-id
PHONEPE_CLIENT_SECRET=your-phonepe-client-secret
PHONEPE_CLIENT_VERSION=1
PHONEPE_ENV=SANDBOX
PHONEPE_REDIRECT_URL_BASE=http://localhost:3000
PHONEPE_CALLBACK_URL=http://localhost:5000/api/bookings/phonepe/callback
PHONEPE_CALLBACK_USERNAME=your-callback-username
PHONEPE_CALLBACK_PASSWORD=your-callback-password
